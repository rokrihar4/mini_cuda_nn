   "source": [
    "import torch\n",
    "\n",
    "x = torch.tensor(2.0, requires_grad=True)\n",
    "y = x**2 + 3*x\n",
    "\n",
    "y.backward() # compute gradient\n",
    "\n",
    "print(x.grad) # dy/dx = 2x + 3\n",
    "\n",
    "x = torch.tensor([[1, 2], [3, 4]])\n",
    "print(x.shape)  # (2, 2)\n",
    "print(x.dim)"
   ]
  }
